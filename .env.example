# Upstash Redis REST (optional locally — app falls back to in-memory store).
# Required in production for persistent leaderboard + AI game storage.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Session HMAC key. Required in production (>=16 chars).
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# Claude API key. If unset, the AI pipeline falls back to deterministic
# mock specs (model: "mock-v1"). Set this in production to generate real
# daily challenges via claude-sonnet-4-6.
ANTHROPIC_API_KEY=

# Shared secret Vercel Cron sends in Authorization: Bearer <secret>.
# If unset, the cron route accepts any caller (dev convenience).
# In production, set this AND configure Vercel to include it.
CRON_SECRET=
