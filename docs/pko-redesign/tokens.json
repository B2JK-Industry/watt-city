{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "navy": {
      "900": { "$type": "color", "$value": "#001e4b" },
      "700": { "$type": "color", "$value": "#003574" },
      "500": { "$type": "color", "$value": "#004c9a" }
    },
    "orange": {
      "700": { "$type": "color", "$value": "#cc7a09" },
      "500": { "$type": "color", "$value": "#db912c" }
    },
    "green": {
      "600": { "$type": "color", "$value": "#2e7d49" }
    },
    "red": {
      "600": { "$type": "color", "$value": "#c0342b" }
    },
    "ink": {
      "900": { "$type": "color", "$value": "#000000" },
      "500": { "$type": "color", "$value": "#636363" },
      "300": { "$type": "color", "$value": "#b7b7b7" }
    },
    "surface": {
      "0": { "$type": "color", "$value": "#ffffff" },
      "50": { "$type": "color", "$value": "#f9f9f9" }
    },
    "line": { "$type": "color", "$value": "#e5e5e5" }
  },
  "radius": {
    "none": { "$type": "dimension", "$value": "0" },
    "sm": { "$type": "dimension", "$value": "4px" },
    "md": { "$type": "dimension", "$value": "10px" },
    "lg": { "$type": "dimension", "$value": "16px" },
    "pill": { "$type": "dimension", "$value": "999px" }
  },
  "shadow": {
    "line": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0",
        "offsetY": "0",
        "blur": "0",
        "spread": "1px",
        "color": "#e5e5e5"
      }
    },
    "soft": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0",
        "offsetY": "3px",
        "blur": "6px",
        "spread": "0",
        "color": "#00000029"
      }
    },
    "softLg": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0",
        "offsetY": "8px",
        "blur": "24px",
        "spread": "0",
        "color": "#0000001f"
      }
    }
  },
  "type": {
    "display": { "$type": "typography", "$value": { "fontSize": "48px", "lineHeight": "56px", "fontWeight": 700 } },
    "h1": { "$type": "typography", "$value": { "fontSize": "40px", "lineHeight": "48px", "fontWeight": 700 } },
    "h2": { "$type": "typography", "$value": { "fontSize": "32px", "lineHeight": "40px", "fontWeight": 700 } },
    "h3": { "$type": "typography", "$value": { "fontSize": "24px", "lineHeight": "32px", "fontWeight": 600 } },
    "h4": { "$type": "typography", "$value": { "fontSize": "20px", "lineHeight": "28px", "fontWeight": 600 } },
    "h5": { "$type": "typography", "$value": { "fontSize": "18px", "lineHeight": "26px", "fontWeight": 600 } },
    "bodyLg": { "$type": "typography", "$value": { "fontSize": "18px", "lineHeight": "28px", "fontWeight": 400 } },
    "body": { "$type": "typography", "$value": { "fontSize": "16px", "lineHeight": "24px", "fontWeight": 400 } },
    "bodySm": { "$type": "typography", "$value": { "fontSize": "14px", "lineHeight": "20px", "fontWeight": 400 } },
    "caption": { "$type": "typography", "$value": { "fontSize": "13px", "lineHeight": "18px", "fontWeight": 400 } },
    "micro": { "$type": "typography", "$value": { "fontSize": "11px", "lineHeight": "14px", "fontWeight": 400 } },
    "overline": { "$type": "typography", "$value": { "fontSize": "12px", "lineHeight": "16px", "fontWeight": 600, "letterSpacing": "0.12em", "textTransform": "uppercase" } }
  }
}
